@page "/admin/scholarships"
@rendermode RenderModes.InteractiveServerNoPrerender
@attribute [Authorize(Roles = ApplicationRoles.SuperAdmin)]
@using MediatR
@inject IMediator Mediator
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<InteractiveProviders />

<PageTitle>Scholarships</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4">Scholarships</MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreate">Add scholarship</MudButton>
</MudStack>

@if (_scholarships is null)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (_scholarships.Count == 0)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">No scholarships yet. Use “Add scholarship” to create one.</MudAlert>
}
else
{
    <MudTable Items="_scholarships" Hover="true" Elevation="0" T="ScholarshipOverviewDto"
              OnRowClick="@((TableRowClickEventArgs<ScholarshipOverviewDto> a) => Open(a.Item))" Class="cursor-pointer">
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Description</MudTh>
            <MudTh>Grants</MudTh>
            <MudTh>Scholars</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Name">@context.Name</MudTd>
            <MudTd DataLabel="Description">@context.Description</MudTd>
            <MudTd DataLabel="Grants">@context.GrantCount</MudTd>
            <MudTd DataLabel="Scholars">@context.ScholarCount</MudTd>
        </RowTemplate>
        <PagerContent><MudTablePager /></PagerContent>
    </MudTable>
}

<MudDialog @bind-Visible="_showCreate">
    <TitleContent><MudText Typo="Typo.h6">Add scholarship</MudText></TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_name" Label="Name" Class="mb-2" />
        <MudTextField @bind-Value="_description" Label="Description" Lines="2" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showCreate = false)">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CreateAsync" Disabled="_busy">Create</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<ScholarshipOverviewDto>? _scholarships;
    private bool _showCreate;
    private bool _busy;
    private string _name = string.Empty;
    private string _description = string.Empty;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync() => _scholarships = await Mediator.Send(new GetScholarshipsOverviewQuery());

    private void Open(ScholarshipOverviewDto s) => Nav.NavigateTo($"/admin/scholarships/{s.Id}");

    private void OpenCreate()
    {
        _name = _description = string.Empty;
        _showCreate = true;
    }

    private async Task CreateAsync()
    {
        _busy = true;
        try
        {
            await Mediator.Send(new CreateScholarshipCommand(_name, _description));
            Snackbar.Add("Scholarship created.", Severity.Success);
            _showCreate = false;
            await LoadAsync();
        }
        catch (DomainException ex) { Snackbar.Add(ex.Message, Severity.Error); }
        catch (FluentValidation.ValidationException ex) { Snackbar.Add(string.Join(" ", ex.Errors.Select(e => e.ErrorMessage)), Severity.Error); }
        finally { _busy = false; }
    }
}
