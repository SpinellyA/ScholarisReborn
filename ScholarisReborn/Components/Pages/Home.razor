@page "/"
@rendermode InteractiveServer
@using System.Security.Claims
@using MediatR
@inject IMediator Mediator

<PageTitle>Scholaris</PageTitle>

<AuthorizeView>
    <Authorized>
        @if (_isSuperAdmin || _isAdmin)
        {
            <div class="scholaris-hero mb-6">
                <MudText Typo="Typo.h4" Class="mb-1">Welcome back, @_displayName</MudText>
                <MudText Typo="Typo.body1" Style="opacity:0.85;">
                    @(_isSuperAdmin ? "SuperAdmin" : "Admin") access &middot; CHED Scholar Information System
                </MudText>
            </div>

            <MudGrid>
                <MudItem xs="12" sm="6" md="3">
                    <MudCard Class="scholaris-tile pa-2" Elevation="2">
                        <MudCardContent>
                            <div class="scholaris-tile-icon mb-2" style="background:var(--mud-palette-info-hover);">
                                <MudIcon Icon="@Icons.Material.Filled.MailOutline" Color="Color.Info" />
                            </div>
                            <MudText Typo="Typo.h5">@_pendingInvitations</MudText>
                            <MudText Typo="Typo.body2">Pending invitations</MudText>
                        </MudCardContent>
                        <MudCardActions>
                            <MudButton Href="admin/invitations" Variant="Variant.Text" Color="Color.Primary">Manage</MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>

                @if (_isSuperAdmin)
                {
                    <MudItem xs="12" sm="6" md="3">
                        <MudCard Class="scholaris-tile pa-2" Elevation="2">
                            <MudCardContent>
                                <div class="scholaris-tile-icon mb-2" style="background:var(--mud-palette-primary-hover);">
                                    <MudIcon Icon="@Icons.Material.Filled.School" Color="Color.Primary" />
                                </div>
                                <MudText Typo="Typo.h5">@_schoolCount</MudText>
                                <MudText Typo="Typo.body2">Schools</MudText>
                            </MudCardContent>
                            <MudCardActions>
                                <MudButton Href="admin/schools" Variant="Variant.Text" Color="Color.Primary">Manage</MudButton>
                            </MudCardActions>
                        </MudCard>
                    </MudItem>

                    <MudItem xs="12" sm="6" md="3">
                        <MudCard Class="scholaris-tile pa-2" Elevation="2">
                            <MudCardContent>
                                <div class="scholaris-tile-icon mb-2" style="background:var(--mud-palette-secondary-hover);">
                                    <MudIcon Icon="@Icons.Material.Filled.CardGiftcard" Color="Color.Secondary" />
                                </div>
                                <MudText Typo="Typo.h5">@_scholarshipCount</MudText>
                                <MudText Typo="Typo.body2">Scholarships</MudText>
                            </MudCardContent>
                            <MudCardActions>
                                <MudButton Href="admin/scholarships" Variant="Variant.Text" Color="Color.Primary">Manage</MudButton>
                            </MudCardActions>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        }
        else
        {
            <div class="scholaris-hero mb-6">
                <MudText Typo="Typo.h4" Class="mb-1">Welcome, @_displayName</MudText>
                <MudText Typo="Typo.body1" Style="opacity:0.85;">Scholar access &middot; CHED Scholar Information System</MudText>
            </div>

            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                Your scholar dashboard (submission status, stipend tracking, and scholarship details) is on its way.
                Check back soon.
            </MudAlert>
        }
    </Authorized>
    <NotAuthorized>
        <div class="scholaris-hero">
            <MudText Typo="Typo.h3" Class="mb-2">Scholaris</MudText>
            <MudText Typo="Typo.h6" Class="mb-4" Style="opacity:0.9;">The CHED Scholar Information System</MudText>
            <MudText Typo="Typo.body1" Class="mb-6" Style="max-width:640px;opacity:0.9;">
                One secure place for scholars and administrators to manage submissions, scholarships, and
                school terms &mdash; replacing shared folders with proper accountability and access control.
            </MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Secondary" Href="login" Class="mr-2">Log in</MudButton>
            <MudButton Variant="Variant.Outlined" Style="color:white;border-color:white;" Href="register">Register</MudButton>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    private bool _isSuperAdmin;
    private bool _isAdmin;
    private string _displayName = string.Empty;

    private int _pendingInvitations;
    private int _schoolCount;
    private int _scholarshipCount;

    protected override async Task OnInitializedAsync()
    {
        if (AuthStateTask is null)
            return;

        var authState = await AuthStateTask;
        var user = authState.User;

        if (!(user.Identity?.IsAuthenticated ?? false))
            return;

        _isSuperAdmin = user.IsInRole(ApplicationRoles.SuperAdmin);
        _isAdmin = user.IsInRole(ApplicationRoles.Admin);
        _displayName = user.Identity?.Name ?? "there";

        if (_isSuperAdmin || _isAdmin)
        {
            var invitations = await Mediator.Send(new GetInvitationsQuery());
            _pendingInvitations = invitations.Count(i => i.Status == InvitationStatus.Pending);

            if (_isSuperAdmin)
            {
                _schoolCount = (await Mediator.Send(new GetSchoolsQuery())).Count;
                _scholarshipCount = (await Mediator.Send(new GetScholarshipsQuery())).Count;
            }
        }
    }
}
