@inherits LayoutComponentBase

<MudThemeProvider Theme="@_theme" IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<MudLayout>
    <MudAppBar Elevation="2">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
        <div class="scholaris-brand ml-3">
            <MudIcon Icon="@Icons.Material.Filled.School" Size="Size.Large" />
            <div>
                <MudText Typo="Typo.h6" Class="scholaris-brand-name">Scholaris</MudText>
                <MudText Typo="Typo.caption" Class="scholaris-brand-subtitle d-none d-sm-block">CHED Scholar Information System</MudText>
            </div>
        </div>
        <MudSpacer />
        <MudIconButton Icon="@(DarkLightModeButtonIcon)" Color="Color.Inherit" OnClick="@DarkModeToggle" Title="Toggle light/dark mode" />
    </MudAppBar>
    <MudDrawer id="nav-drawer" @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="1">
        <NavMenu />
    </MudDrawer>
    <MudMainContent Class="pt-16 pa-4">
        @Body
    </MudMainContent>
</MudLayout>


<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode = true;
    private MudTheme? _theme = null;

    protected override void OnInitialized()
    {
        base.OnInitialized();

        _theme = new()
        {
            PaletteLight = _lightPalette,
            PaletteDark = _darkPalette,
            Typography = new Typography
            {
                Default = new DefaultTypography { FontFamily = ["Roboto", "Helvetica", "Arial", "sans-serif"] }
            },
            LayoutProperties = new LayoutProperties
            {
                DefaultBorderRadius = "10px"
            }
        };
    }

    private void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }

    private void DarkModeToggle()
    {
        _isDarkMode = !_isDarkMode;
    }

    // Navy blue for institutional trust, warm gold as the "scholar achievement" accent —
    // a Philippine academic/government feel without literally reproducing the flag.
    private readonly PaletteLight _lightPalette = new()
    {
        Primary = "#14315C",
        PrimaryDarken = "#0D2240",
        PrimaryLighten = "#2A4D80",
        Secondary = "#C9A227",
        Black = "#14151a",
        Background = "#F4F6F9",
        BackgroundGray = "#EAEDF2",
        Surface = "#FFFFFF",
        AppbarText = "#FFFFFF",
        AppbarBackground = "#14315C",
        DrawerBackground = "#FFFFFF",
        DrawerText = "#3A3F47",
        DrawerIcon = "#5B6472",
        TextPrimary = "#23262B",
        TextSecondary = "#5B6472",
        Success = "#2E9E5B",
        Warning = "#D98E04",
        Error = "#D1435B",
        Info = "#2E6FB4",
        GrayLight = "#E8E8E8",
        GrayLighter = "#f9f9f9",
        LinesDefault = "#DEE2E8",
        TableLines = "#DEE2E8",
        Divider = "#E2E5EA",
    };

    private readonly PaletteDark _darkPalette = new()
    {
        Primary = "#5C8DD6",
        PrimaryDarken = "#3D6FB4",
        PrimaryLighten = "#8AAEE0",
        Secondary = "#E0B83D",
        Surface = "#1A2230",
        Background = "#11151C",
        BackgroundGray = "#161D29",
        AppbarText = "#E4E7EC",
        AppbarBackground = "#0F1722",
        DrawerBackground = "#161D29",
        ActionDefault = "#8893A3",
        ActionDisabled = "#9999994d",
        ActionDisabledBackground = "#605f6d4d",
        TextPrimary = "#E4E7EC",
        TextSecondary = "#9AA5B1",
        TextDisabled = "#ffffff33",
        DrawerIcon = "#9AA5B1",
        DrawerText = "#C3CAD4",
        GrayLight = "#232C3D",
        GrayLighter = "#1A2230",
        Info = "#5C8DD6",
        Success = "#3dcb6c",
        Warning = "#E0B83D",
        Error = "#ff3f5f",
        LinesDefault = "#2A3344",
        TableLines = "#2A3344",
        Divider = "#232C3D",
        OverlayLight = "#1A223080",
    };

    public string DarkLightModeButtonIcon => _isDarkMode switch
    {
        true => Icons.Material.Rounded.AutoMode,
        false => Icons.Material.Outlined.DarkMode,
    };
}
