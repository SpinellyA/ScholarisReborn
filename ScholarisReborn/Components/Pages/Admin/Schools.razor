@page "/admin/schools"
@rendermode RenderModes.InteractiveServerNoPrerender
@attribute [Authorize(Roles = ApplicationRoles.SuperAdmin)]
@using MediatR
@inject IMediator Mediator
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<InteractiveProviders />

<PageTitle>Schools</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4">Schools</MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="@(() => OpenCreate())">Add school</MudButton>
</MudStack>

@if (_schools is null)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (_schools.Count == 0)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">No schools yet. Use “Add school” to create one.</MudAlert>
}
else
{
    <MudTable Items="_schools" Hover="true" Elevation="0" T="SchoolOverviewDto"
              OnRowClick="@((TableRowClickEventArgs<SchoolOverviewDto> a) => Open(a.Item))" Class="cursor-pointer">
        <HeaderContent>
            <MudTh>Code</MudTh>
            <MudTh>Name</MudTh>
            <MudTh>Region</MudTh>
            <MudTh>Term system</MudTh>
            <MudTh>Active scholars</MudTh>
            <MudTh>Current term</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Code">@context.SchoolCode</MudTd>
            <MudTd DataLabel="Name">@context.Name</MudTd>
            <MudTd DataLabel="Region">@context.Region</MudTd>
            <MudTd DataLabel="Term system">@context.TermSystem</MudTd>
            <MudTd DataLabel="Active scholars">@context.ActiveScholars</MudTd>
            <MudTd DataLabel="Current term">
                @if (context.OpenTermNumber is not null)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Success">Term @context.OpenTermNumber open</MudChip>
                }
                else
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Default">No open term</MudChip>
                }
            </MudTd>
        </RowTemplate>
        <PagerContent><MudTablePager /></PagerContent>
    </MudTable>
}

<MudDialog @bind-Visible="_showCreate">
    <TitleContent><MudText Typo="Typo.h6">Add school</MudText></TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_code" Label="School code" Class="mb-2" />
        <MudTextField @bind-Value="_name" Label="Name" Class="mb-2" />
        <MudTextField @bind-Value="_description" Label="Description" Lines="2" Class="mb-2" />
        <MudSelect T="Region" Label="Region" @bind-Value="_region" Class="mb-2">
            @foreach (var r in Enum.GetValues<Region>()) { <MudSelectItem Value="@r">@r</MudSelectItem> }
        </MudSelect>
        <MudSelect T="TermSystem" Label="Term system" @bind-Value="_termSystem">
            @foreach (var t in Enum.GetValues<TermSystem>()) { <MudSelectItem Value="@t">@t</MudSelectItem> }
        </MudSelect>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showCreate = false)">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CreateAsync" Disabled="_busy">Create</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<SchoolOverviewDto>? _schools;
    private bool _showCreate;
    private bool _busy;

    private string _code = string.Empty;
    private string _name = string.Empty;
    private string _description = string.Empty;
    private Region _region;
    private TermSystem _termSystem;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync() => _schools = await Mediator.Send(new GetSchoolsOverviewQuery());

    private void Open(SchoolOverviewDto s) => Nav.NavigateTo($"/admin/schools/{s.Id}");

    private void OpenCreate()
    {
        _code = _name = _description = string.Empty;
        _region = Region.NCR;
        _termSystem = TermSystem.Semestral;
        _showCreate = true;
    }

    private async Task CreateAsync()
    {
        _busy = true;
        try
        {
            await Mediator.Send(new CreateSchoolCommand(_code, _name, _description, _region, _termSystem));
            Snackbar.Add("School created.", Severity.Success);
            _showCreate = false;
            await LoadAsync();
        }
        catch (DomainException ex) { Snackbar.Add(ex.Message, Severity.Error); }
        catch (FluentValidation.ValidationException ex) { Snackbar.Add(string.Join(" ", ex.Errors.Select(e => e.ErrorMessage)), Severity.Error); }
        finally { _busy = false; }
    }
}
