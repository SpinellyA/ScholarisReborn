@using System.Security.Claims
@using MediatR
@inject IMediator Mediator
@inject NavigationManager Nav

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (_dto is null)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
        We couldn't find a scholar profile for your account. Please contact an administrator.
    </MudAlert>
}
else
{
    <div class="scholaris-hero mb-6">
        <MudText Typo="Typo.h4" Class="mb-1">Welcome, @_dto.FullName</MudText>
        <MudText Typo="Typo.body1" Style="opacity:0.85;">@_dto.ScholarshipName &middot; Batch @_dto.BatchNumber &middot; @_dto.SchoolName</MudText>
    </div>

    <MudGrid>
        <!-- Profile -->
        <MudItem xs="12" md="6">
            <MudCard Class="scholaris-card" Elevation="2" Style="height:100%">
                <MudCardContent>
                    <MudText Typo="Typo.h6" GutterBottom="true">Profile</MudText>
                    <MudText><b>Name:</b> @_dto.FullName</MudText>
                    @if (_dto.Age is not null) { <MudText><b>Age:</b> @_dto.Age</MudText> }
                    <MudText><b>University:</b> @_dto.SchoolName</MudText>
                    <MudText><b>Program:</b> @_dto.DegreeProgram</MudText>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" Href="/profile">Edit profile</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>

        <!-- Scholarship status -->
        <MudItem xs="12" md="6">
            <MudCard Class="scholaris-card cursor-pointer" Elevation="2" Style="height:100%" @onclick="@(() => _showStatus = true)">
                <MudCardContent Class="d-flex flex-column justify-center align-center" Style="height:100%">
                    <MudText Typo="Typo.overline">Scholarship status</MudText>
                    <MudChip T="string" Color="@StatusColor(_dto.Status)" Size="Size.Large" Variant="Variant.Filled">@StatusLabel(_dto.Status)</MudChip>
                    <MudText Typo="Typo.caption" Class="mt-2">Click for details</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Compliance -->
        <MudItem xs="12" md="6">
            <MudCard Class="scholaris-card cursor-pointer" Elevation="2" Style="height:100%" @onclick="GoSubmit">
                <MudCardContent>
                    <MudText Typo="Typo.h6" GutterBottom="true">Semestral compliance</MudText>
                    @switch (_dto.Compliance)
                    {
                        case ComplianceState.NoOpenTerm:
                            <MudAlert Severity="Severity.Info" Variant="Variant.Text" Dense="true">No open term. Submissions are currently closed.</MudAlert>
                            break;
                        case ComplianceState.NeedsSubmission:
                            <MudAlert Severity="Severity.Warning" Variant="Variant.Text" Dense="true">Term @_dto.OpenTermNumber is open — please submit your requirements.</MudAlert>
                            break;
                        case ComplianceState.Submitted:
                            <MudAlert Severity="Severity.Success" Variant="Variant.Text" Dense="true">Your requirements for term @_dto.OpenTermNumber have been submitted.</MudAlert>
                            break;
                    }
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Text" Color="Color.Primary">Go to submissions</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>

        <!-- Stipend -->
        <MudItem xs="12" md="6">
            <MudCard Class="scholaris-card" Elevation="2" Style="height:100%">
                <MudCardContent>
                    <MudText Typo="Typo.h6" GutterBottom="true">Latest stipend</MudText>
                    @if (_dto.LatestStipend is null)
                    {
                        <MudText Typo="Typo.body2">No stipend announcements yet.</MudText>
                    }
                    else
                    {
                        <MudText Typo="Typo.h5">₱@_dto.LatestStipend.Amount.ToString("N2")</MudText>
                        <MudText Typo="Typo.body2">@_dto.LatestStipend.Description</MudText>
                        <MudText Typo="Typo.caption">Announced @_dto.LatestStipend.AnnouncedAt.ToLocalTime().ToString("MMM dd, yyyy")</MudText>
                        <div class="mt-2">
                            @if (_dto.LatestStipend.Received is null)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Warning">Awaiting your confirmation</MudChip>
                            }
                            else if (_dto.LatestStipend.Received == true)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Success">Confirmed received</MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Error">Disputed</MudChip>
                            }
                        </div>
                    }
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" Href="/scholarship/report">View history</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>

    <MudDialog @bind-Visible="_showStatus">
        <TitleContent><MudText Typo="Typo.h6">Scholarship details</MudText></TitleContent>
        <DialogContent>
            <MudText><b>Name:</b> @_dto.FullName</MudText>
            <MudText><b>Email:</b> @_dto.Email</MudText>
            <MudText><b>Scholarship:</b> @_dto.ScholarshipName</MudText>
            <MudText><b>Batch:</b> @_dto.BatchNumber</MudText>
            <MudText><b>Program:</b> @_dto.DegreeProgram</MudText>
            <MudText><b>University:</b> @_dto.SchoolName</MudText>
            <MudText Class="mt-1"><b>Status:</b> <MudChip T="string" Size="Size.Small" Color="@StatusColor(_dto.Status)">@StatusLabel(_dto.Status)</MudChip></MudText>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => _showStatus = false)" Color="Color.Primary">Close</MudButton>
        </DialogActions>
    </MudDialog>
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthStateTask { get; set; }

    private bool _loading = true;
    private bool _showStatus;
    private ScholarDashboardDto? _dto;

    protected override async Task OnInitializedAsync()
    {
        Guid userId = Guid.Empty;
        if (AuthStateTask is not null)
        {
            var state = await AuthStateTask;
            var id = state.User.FindFirstValue(ClaimTypes.NameIdentifier);
            if (id is not null) userId = Guid.Parse(id);
        }

        _dto = await Mediator.Send(new GetScholarDashboardQuery(userId));
        _loading = false;
    }

    private void GoSubmit() => Nav.NavigateTo("/submit");

    private static string StatusLabel(ScholasticStatus s) => s switch
    {
        ScholasticStatus.Active => "SCHOLAR",
        ScholasticStatus.Withheld => "WITHHELD",
        ScholasticStatus.Terminated => "TERMINATED",
        ScholasticStatus.Graduated => "GRADUATED",
        _ => s.ToString().ToUpperInvariant()
    };

    private static Color StatusColor(ScholasticStatus s) => s switch
    {
        ScholasticStatus.Active => Color.Success,
        ScholasticStatus.Withheld => Color.Warning,
        ScholasticStatus.Terminated => Color.Error,
        ScholasticStatus.Graduated => Color.Info,
        _ => Color.Default
    };
}
