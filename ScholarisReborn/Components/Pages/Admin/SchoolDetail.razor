@page "/admin/schools/{SchoolId:guid}"
@rendermode RenderModes.InteractiveServerNoPrerender
@attribute [Authorize(Roles = $"{ApplicationRoles.SuperAdmin},{ApplicationRoles.Admin}")]
@using MediatR
@inject IMediator Mediator
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<InteractiveProviders />

<PageTitle>School</PageTitle>

@if (_school is null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudBreadcrumbs Items="_crumbs" Class="px-0 mb-4" />

    <MudGrid Spacing="4">

        <!-- LEFT: summary + actions -->
        <MudItem xs="12" md="4">
            <MudCard Class="scholaris-card" Elevation="2">
                <MudCardContent>
                    <div class="d-flex justify-center mb-3">
                        @if (_school.HasLogo)
                        {
                            <MudAvatar Style="height:96px; width:96px;"><MudImage Src="@($"/school-logo/{_school.Id}?v={_logoVersion}")" /></MudAvatar>
                        }
                        else
                        {
                            <MudAvatar Color="Color.Primary" Style="height:96px; width:96px; font-size:2rem;">@(_school.Name.Length > 0 ? _school.Name[0] : '?')</MudAvatar>
                        }
                    </div>
                    @if (_isSuperAdmin)
                    {
                        <div class="d-flex justify-center mb-3" style="gap:8px;">
                            <MudFileUpload T="IBrowserFile" FilesChanged="UploadLogoAsync" Accept="image/*">
                                <ActivatorContent>
                                    <MudButton Variant="Variant.Text" Size="Size.Small" StartIcon="@Icons.Material.Filled.Image" Disabled="_busy">
                                        @(_school.HasLogo ? "Change logo" : "Add logo")
                                    </MudButton>
                                </ActivatorContent>
                            </MudFileUpload>
                            @if (_school.HasLogo)
                            {
                                <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete" OnClick="RemoveLogoAsync" Disabled="_busy">Remove</MudButton>
                            }
                        </div>
                    }
                    <MudText Typo="Typo.h5" Align="Align.Center">@_school.Name</MudText>
                    <MudText Typo="Typo.body2" Align="Align.Center" Class="mb-3">@_school.SchoolCode</MudText>

                    <MudList T="string" Dense="true">
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Place">@_school.Region</MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.CalendarMonth">@_school.TermSystem</MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Groups">@_school.ActiveScholarsCount active scholar(s)</MudListItem>
                    </MudList>

                    @if (!string.IsNullOrWhiteSpace(_school.Description))
                    {
                        <MudText Typo="Typo.body2" Class="mt-3">@_school.Description</MudText>
                    }
                </MudCardContent>
                <MudCardActions>
                    <MudButton StartIcon="@Icons.Material.Filled.Edit" Color="Color.Primary" OnClick="OpenEdit">Edit</MudButton>
                    <MudSpacer />
                    <MudButton StartIcon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => _showDelete = true)">Delete</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>

        <!-- RIGHT: term management + history -->
        <MudItem xs="12" md="8">
            <MudStack Spacing="4">

                <MudCard Class="scholaris-card" Elevation="2">
                    <MudCardContent>
                        <MudText Typo="Typo.h6" GutterBottom="true">Current term</MudText>
                        @if (_openTerm is null)
                        {
                            <MudText Typo="Typo.body2" Class="mb-3">No term is open. Open one to start accepting submissions.</MudText>
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <MudSelect T="int" @bind-Value="_periodNumber" Label="@($"{_school.TermSystem} period")" Style="max-width:220px">
                                    @for (var p = 1; p <= _school.PeriodsPerYear; p++)
                                    {
                                        <MudSelectItem Value="@p">@TermSystemInfo.Ordinal(p) @TermSystemInfo.PeriodName(_school.TermSystem)</MudSelectItem>
                                    }
                                </MudSelect>
                                <MudNumericField @bind-Value="_academicYearStart" Label="Academic year start" Min="2000" Style="max-width:180px" />
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OpenTermAsync" Disabled="_busy">Open term</MudButton>
                            </MudStack>
                            <MudText Typo="Typo.caption" Class="mt-2">
                                Will open: <b>@TermSystemInfo.Label(_school.TermSystem, _academicYearStart, _periodNumber)</b>
                            </MudText>
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Class="mb-3">
                                @_openTerm.Label is open (started @_openTerm.StartedAt.ToLocalTime().ToString("g")).
                            </MudAlert>
                            <MudButton Variant="Variant.Filled" Color="Color.Warning" StartIcon="@Icons.Material.Filled.LockClock" OnClick="@(() => _showClose = true)" Disabled="_busy">Close term</MudButton>
                            <MudText Typo="Typo.caption" Class="mt-2">
                                Closing auto-withholds any active scholar who didn't submit their requirements this term.
                            </MudText>
                        }
                    </MudCardContent>
                </MudCard>

                <MudCard Class="scholaris-card" Elevation="2">
                    <MudCardContent>
                        <MudText Typo="Typo.h6" GutterBottom="true">Term history</MudText>
                        @if (_school.Terms.Count == 0)
                        {
                            <MudText Typo="Typo.body2">No terms yet.</MudText>
                        }
                        else
                        {
                            <MudTable Items="_school.Terms.OrderByDescending(t => t.TermNumber)" Hover="true" Elevation="0" Dense="true">
                                <HeaderContent>
                                    <MudTh>Term</MudTh><MudTh>Started</MudTh><MudTh>Ended</MudTh><MudTh>Status</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd>@context.Label</MudTd>
                                    <MudTd>@context.StartedAt.ToLocalTime().ToString("g")</MudTd>
                                    <MudTd>@(context.EndedAt?.ToLocalTime().ToString("g") ?? "—")</MudTd>
                                    <MudTd><MudChip T="string" Size="Size.Small" Color="@(context.IsOpen ? Color.Success : Color.Default)">@(context.IsOpen ? "Open" : "Closed")</MudChip></MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                    </MudCardContent>
                </MudCard>

            </MudStack>
        </MudItem>
    </MudGrid>

    <!-- EDIT DIALOG -->
    <MudDialog @bind-Visible="_showEdit">
        <TitleContent><MudText Typo="Typo.h6">Edit school</MudText></TitleContent>
        <DialogContent>
            <MudTextField @bind-Value="_eCode" Label="School code" Class="mb-2" />
            <MudTextField @bind-Value="_eName" Label="Name" Class="mb-2" />
            <MudTextField @bind-Value="_eDescription" Label="Description" Lines="2" Class="mb-2" />
            <MudSelect T="Region" Label="Region" @bind-Value="_eRegion" Class="mb-2">
                @foreach (var r in Enum.GetValues<Region>()) { <MudSelectItem Value="@r">@r</MudSelectItem> }
            </MudSelect>
            <MudSelect T="TermSystem" Label="Term system" @bind-Value="_eTermSystem">
                @foreach (var t in Enum.GetValues<TermSystem>()) { <MudSelectItem Value="@t">@t</MudSelectItem> }
            </MudSelect>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => _showEdit = false)">Cancel</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveEditAsync" Disabled="_busy">Save</MudButton>
        </DialogActions>
    </MudDialog>

    <!-- DELETE CONFIRM -->
    <MudDialog @bind-Visible="_showDelete">
        <TitleContent><MudText Typo="Typo.h6">Delete school?</MudText></TitleContent>
        <DialogContent>
            <MudText>This permanently deletes <b>@_school.Name</b> and its term history. This can't be undone.</MudText>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => _showDelete = false)">Cancel</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="DeleteAsync" Disabled="_busy">Delete</MudButton>
        </DialogActions>
    </MudDialog>

    <!-- CLOSE TERM CONFIRM -->
    <MudDialog @bind-Visible="_showClose">
        <TitleContent><MudText Typo="Typo.h6">Close @_openTerm?.Label?</MudText></TitleContent>
        <DialogContent>
            <MudText>Active scholars who didn't submit this term will be automatically withheld.</MudText>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => _showClose = false)">Cancel</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Warning" OnClick="CloseTermAsync" Disabled="_busy">Close term</MudButton>
        </DialogActions>
    </MudDialog>
}

@code {
    [Parameter] public Guid SchoolId { get; set; }

    private SchoolDetailsDto? _school;
    private TermDto? _openTerm;
    private int _academicYearStart = DateTime.Today.Year;
    private int _periodNumber = 1;
    private bool _busy;
    private bool _isSuperAdmin;
    private int _logoVersion;
    private List<BreadcrumbItem> _crumbs = new();

    private bool _showEdit, _showDelete, _showClose;
    private string _eCode = "", _eName = "", _eDescription = "";
    private Region _eRegion;
    private TermSystem _eTermSystem;

    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is not null)
        {
            var state = await AuthState;
            _isSuperAdmin = state.User.IsInRole(ApplicationRoles.SuperAdmin);
        }
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _school = await Mediator.Send(new GetSchoolByIdQuery(SchoolId));
        _openTerm = _school?.Terms.FirstOrDefault(t => t.IsOpen);
        if (_school is not null)
        {
            _academicYearStart = _school.SuggestedAcademicYearStart;
            _periodNumber = _school.SuggestedPeriodNumber;
        }
        _crumbs = new()
        {
            new BreadcrumbItem("Schools", "/admin/schools"),
            new BreadcrumbItem(_school?.Name ?? "School", null, disabled: true)
        };
    }

    private void OpenEdit()
    {
        if (_school is null) return;
        _eCode = _school.SchoolCode;
        _eName = _school.Name;
        _eDescription = _school.Description;
        _eRegion = _school.Region;
        _eTermSystem = _school.TermSystem;
        _showEdit = true;
    }

    private async Task SaveEditAsync()
        => await Run(async () =>
        {
            await Mediator.Send(new UpdateSchoolCommand(SchoolId, _eCode, _eName, _eDescription, _eRegion, _eTermSystem));
            Snackbar.Add("School updated.", Severity.Success);
            _showEdit = false;
            await LoadAsync();
        });

    private async Task DeleteAsync()
        => await Run(async () =>
        {
            await Mediator.Send(new DeleteSchoolCommand(SchoolId));
            Snackbar.Add("School deleted.", Severity.Success);
            Nav.NavigateTo("/admin/schools");
        });

    private async Task OpenTermAsync()
        => await Run(async () =>
        {
            await Mediator.Send(new OpenTermCommand(SchoolId, _academicYearStart, _periodNumber));
            Snackbar.Add("Term opened.", Severity.Success);
            await LoadAsync();
        });

    private async Task UploadLogoAsync(IBrowserFile? file)
    {
        if (file is null) return;
        await Run(async () =>
        {
            using var stream = file.OpenReadStream(5 * 1024 * 1024);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            await Mediator.Send(new SetSchoolLogoCommand(SchoolId, ms.ToArray(), file.ContentType));
            _logoVersion++;
            Snackbar.Add("Logo updated.", Severity.Success);
            await LoadAsync();
        });
    }

    private async Task RemoveLogoAsync()
        => await Run(async () =>
        {
            await Mediator.Send(new SetSchoolLogoCommand(SchoolId, Array.Empty<byte>(), string.Empty));
            _logoVersion++;
            Snackbar.Add("Logo removed.", Severity.Success);
            await LoadAsync();
        });

    private async Task CloseTermAsync()
        => await Run(async () =>
        {
            if (_openTerm is null) return;
            await Mediator.Send(new CloseTermCommand(SchoolId, _openTerm.Id));
            Snackbar.Add("Term closed.", Severity.Success);
            _showClose = false;
            await LoadAsync();
        });

    private async Task Run(Func<Task> action)
    {
        _busy = true;
        try { await action(); }
        catch (DomainException ex) { Snackbar.Add(ex.Message, Severity.Error); }
        catch (FluentValidation.ValidationException ex) { Snackbar.Add(string.Join(" ", ex.Errors.Select(e => e.ErrorMessage)), Severity.Error); }
        finally { _busy = false; }
    }
}
