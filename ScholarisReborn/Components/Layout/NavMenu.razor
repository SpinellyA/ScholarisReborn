
<MudNavMenu>
    <MudNavLink Href="" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">Home</MudNavLink>
    <MudNavLink Href="counter" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Add">Counter</MudNavLink>

    <MudNavLink Href="weather" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.List">Weather</MudNavLink>

    <AuthorizeView Roles="@($"{ApplicationRoles.SuperAdmin},{ApplicationRoles.Admin}")">
        <Authorized>
            <MudDivider Class="my-2" />
            <MudNavLink Href="admin/invitations" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.MailOutline">Invitations</MudNavLink>
            <AuthorizeView Roles="@ApplicationRoles.SuperAdmin" Context="superAdminContext">
                <Authorized>
                    <MudNavLink Href="admin/schools" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.School">Schools</MudNavLink>
                    <MudNavLink Href="admin/scholarships" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.CardGiftcard">Scholarships</MudNavLink>
                </Authorized>
            </AuthorizeView>
        </Authorized>
    </AuthorizeView>

    <MudDivider Class="my-2" />

    <AuthorizeView>
        <Authorized>
            <MudText Class="px-4 py-2" Typo="Typo.body2">Signed in as @context.User.Identity?.Name</MudText>
            <MudNavLink Href="logout" Icon="@Icons.Material.Filled.Logout">Log out</MudNavLink>
        </Authorized>
        <NotAuthorized>
            <MudNavLink Href="login" Icon="@Icons.Material.Filled.Login">Log in</MudNavLink>
            <MudNavLink Href="register" Icon="@Icons.Material.Filled.PersonAdd">Register</MudNavLink>
        </NotAuthorized>
    </AuthorizeView>
</MudNavMenu>

