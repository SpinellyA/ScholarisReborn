
<MudNavMenu>
    <MudText Typo="Typo.body2" Class="scholaris-nav-section">Overview</MudText>
    <MudNavLink Href="" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>

    <AuthorizeView Roles="@ApplicationRoles.Scholar">
        <Authorized>
            <MudText Typo="Typo.body2" Class="scholaris-nav-section">Scholar</MudText>
            <MudNavLink Href="submit" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.UploadFile">Submit Report</MudNavLink>
        </Authorized>
    </AuthorizeView>

    <AuthorizeView Roles="@($"{ApplicationRoles.SuperAdmin},{ApplicationRoles.Admin}")">
        <Authorized>
            <MudText Typo="Typo.body2" Class="scholaris-nav-section">Administration</MudText>
            <MudNavLink Href="admin/records" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.FactCheck">Records</MudNavLink>
            <MudNavLink Href="admin/invitations" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.MailOutline">Invitations</MudNavLink>
            <AuthorizeView Roles="@ApplicationRoles.SuperAdmin" Context="superAdminContext">
                <Authorized>
                    <MudNavLink Href="admin/schools" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.School">Schools</MudNavLink>
                    <MudNavLink Href="admin/scholarships" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.CardGiftcard">Scholarships</MudNavLink>
                </Authorized>
            </AuthorizeView>
        </Authorized>
    </AuthorizeView>

    <MudText Typo="Typo.body2" Class="scholaris-nav-section">Account</MudText>
    <AuthorizeView>
        <Authorized>
            <MudText Class="px-4 py-2" Typo="Typo.body2">Signed in as @context.User.Identity?.Name</MudText>
            <MudNavLink Href="logout" Icon="@Icons.Material.Filled.Logout">Log out</MudNavLink>
        </Authorized>
        <NotAuthorized>
            <MudNavLink Href="login" Icon="@Icons.Material.Filled.Login">Log in</MudNavLink>
            <MudNavLink Href="register" Icon="@Icons.Material.Filled.PersonAdd">Register</MudNavLink>
        </NotAuthorized>
    </AuthorizeView>
</MudNavMenu>
